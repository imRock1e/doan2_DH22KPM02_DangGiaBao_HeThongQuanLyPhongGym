<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <title>Exotic Dashboard</title>
    <link rel="stylesheet" href="/styles/style.css" />
  </head>

  <body>
    <div class="admin">
      <!-- SIDEBAR -->
      <aside class="sidebar">
        <h2>EXOTIC CENTER</h2>

        <nav>
          <a href="/admin">Dashboard</a>
          <a href="/admin/checkin" target="_blank">Trang Checkin</a>
          <a href="/admin/customer">Khách hàng</a>
          <a href="/admin/invoice">Hóa đơn</a>
          <a href="/admin/package">Gói tập</a>
          <a href="/admin/staff">Nhân Viên</a>
          <a href="/admin/invoice/create" target="_blank">Tạo Hóa đơn</a>
        </nav>
      </aside>

      <!-- CONTENT -->
      <main class="content">
        <!-- HEADER -->
        <div class="header">
          <div class="page-title">
            <h1>Danh Sách Khách Hàng</h1>
          </div>

          <div class="header-right">
            <div class="user-menu" onclick="goProfile()">
              <img id="avatar" src="https://i.pravatar.cc/40" class="avatar" />
              <span id="username" class="username"></span>
            </div>

            <button class="logout-btn" onclick="logout()">Logout</button>
          </div>
        </div>

        <!-- FILTER -->
        <div class="filter-bar">
          <input id="guestSearch" type="text" placeholder="Search name or phone" oninput="searchGuest()" />

          <input type="date" />

          <select>
            <option>Status</option>
            <option>Active</option>
            <option>Expired</option>
          </select>

          <a href="/admin/customer/create">Thêm Khách Hàng</a>
        </div>

        <!-- TABLE -->
        <div class="table-wrapper">
          <table>
            <colgroup>
              <col style="width: 70px" />
              <col style="width: 60px" />
              <col style="width: 200px" />
              <col style="width: 150px" />
              <col style="width: 150px" />
              <col style="width: 120px" />
              <col style="width: 150px" />
            </colgroup>
            <thead>
              <tr>
                <th>Ảnh</th>
                <th>ID</th>
                <th>Tên</th>
                <th>SĐT</th>
                <th>Ngày hết hạn</th>
                <th>Trạng Thái</th>
                <th>Action</th>
              </tr>
            </thead>

            <tbody id="customerTable">
              <!-- DATA -->
            </tbody>
          </table>
        </div>
      </main>
    </div>
    <script>
      async function loadUser() {
        try {
          const res = await fetch("/me");
          const data = await res.json();
          // Chưa đăng nhập -> đá về login
          if (!data.logged || !data.authorized) {
            window.location.href = "/404";
            return;
          }
          // Hiển thị thông tin nếu hợp lệ
          const user = data.user;
          const displayName = user.staff_name || "Admin";
          document.getElementById("username").innerText = displayName;
          const avatarElement = document.getElementById("avatar");

          if (user.role === "staff" || user.id_receptionist) {
            // Nếu là nhân viên
            avatarElement.src = `/photos/staff/${user.image || "default.png"}`;
          }
          // (Tùy chọn) Ẩn hiện tính năng dựa trên Role cụ thể
          if (data.user.role === "admin") {
            console.log("Chào sếp!");
          }
        } catch (error) {
          console.error("Lỗi kết nối:", error);
        }
      }

      async function logout() {
        await fetch("/logout");
        window.location.href = "/login";
      }

      loadUser();

      async function loadCustomers() {
        const res = await fetch("/api/customer");
        const data = await res.json();
        renderGuest(data);
      }

      loadCustomers();

      //API
      async function deleteCustomer(id) {
        await fetch("/api/customer/" + id, {
          method: "DELETE",
        });

        location.href = "/admin/customer";
      }

      async function searchGuest() {
        const keyword = document.getElementById("guestSearch").value;
        const res = await fetch(`/api/search_customer?search=${keyword}`);
        const data = await res.json();
        renderGuest(data);
      }

      function renderGuest(data) {
        const tbody = document.getElementById("customerTable");
        tbody.innerHTML = "";
        data.forEach((c) => {
          const tr = document.createElement("tr");
          tr.innerHTML = `
            <td>
              <img src="/uploads/${c.image}" width="40">
            </td>
            <td>${c.id}</td>
            <td>${c.name}</td>
            <td>${c.phone}</td>
            <td>${c.end_date?.split("T")[0] || ""}</td>
            <td>${c.status || ""}</td>
            <td>
              <a href="/admin/customer/edit?id=${c.id}">Sửa</a>
              <button onclick="deleteCustomer(${c.id})">Xóa</button>
            </td>
          `;
          tbody.appendChild(tr);
        });
      }
    </script>
  </body>
</html>
