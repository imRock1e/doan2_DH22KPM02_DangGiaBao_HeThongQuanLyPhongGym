<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <title>Exotic Dashboard</title>
    <link rel="stylesheet" href="/styles/style.css" />
    <script src="https://cdn.jsdelivr.net/npm/face-api.js/dist/face-api.min.js"></script>
  </head>

  <body>
    <div class="admin">
      <!-- SIDEBAR -->
      <aside class="sidebar">
        <h2>EXOTIC CENTER</h2>

        <nav>
          <a href="/admin">Dashboard</a>
          <a href="/admin/checkin" target="_blank">Trang Checkin</a>
          <a href="/admin/customer">Khách hàng</a>
          <a href="/admin/invoice">Hóa đơn</a>
          <a href="/admin/package">Gói tập</a>
          <a href="/admin/staff">Nhân Viên</a>
          <a href="/admin/invoice/create" target="_blank">Tạo Hóa đơn</a>
        </nav>
      </aside>

      <!-- CONTENT -->
      <main class="content">
        <div class="page-header">
          <h1>Sửa khách</h1>
        </div>

        <!-- CUSTOMER INFO -->
        <div class="card">
          <form id="form">
            <div class="customer-top">
              <div class="image-box">
                <img id="image" />
              </div>

              <div class="info-grid">
                <div class="form-group">
                  <label>ID</label>
                  <input id="id" readonly />
                </div>

                <div class="form-group">
                  <label>Tên</label>
                  <input id="name" />
                </div>

                <div class="form-group">
                  <label>SĐT</label>
                  <input id="phone" />
                </div>

                <div class="form-group">
                  <label>Ngày hết hạn</label>
                  <input type="date" id="end" />
                </div>

                <div class="form-group">
                  <label>Trạng thái</label>
                  <input id="status" readonly />
                </div>
              </div>
            </div>

            <div class="form-group">
              <label>Note</label>
              <textarea id="note"></textarea>
            </div>

            <div class="action-buttons">
              <button class="save-btn">Save</button>
              <button type="button" class="delete-btn" onclick="deleteCustomer()">Delete</button>
            </div>
          </form>
        </div>

        <!-- BILL -->
        <div class="card bill-card">
          <h2>Hóa đơn</h2>

          <div class="bill-table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Package</th>
                  <th>Original</th>
                  <th>Discount</th>
                  <th>Final</th>
                  <th>Date</th>
                </tr>
              </thead>

              <tbody id="billTable"></tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
    <script>
      async function loadUser() {
        try {
          const res = await fetch("/me");
          const data = await res.json();
          // Chưa đăng nhập -> đá về login
          if (!data.logged || !data.authorized) {
            window.location.href = "/404";
            return;
          }
          // Hiển thị thông tin nếu hợp lệ
          const user = data.user;
          const displayName = user.staff_name || "Admin";
          document.getElementById("username").innerText = displayName;
          const avatarElement = document.getElementById("avatar");

          if (user.role === "staff" || user.id_receptionist) {
            // Nếu là nhân viên
            avatarElement.src = `/photos/staff/${user.image || "default.png"}`;
          }
          // (Tùy chọn) Ẩn hiện tính năng dựa trên Role cụ thể
          if (data.user.role === "admin") {
            console.log("Chào sếp!");
          }
        } catch (error) {
          console.error("Lỗi kết nối:", error);
        }
      }

      async function logout() {
        await fetch("/logout");
        window.location.href = "/login";
      }

      loadUser();
      const params = new URLSearchParams(location.search);

      const id = params.get("id");

      async function load() {
        const res = await fetch("/api/customer/" + id);

        const c = await res.json();

        document.getElementById("id").value = c.id;
        document.getElementById("name").value = c.name;
        document.getElementById("phone").value = c.phone;
        document.getElementById("end").value = c.end_date?.split("T")[0] || "";
        document.getElementById("status").value = c.status;
        document.getElementById("note").value = c.note;

        if (c.image) document.getElementById("image").src = "/uploads/" + c.image;
      }

      async function loadBills() {
        const res = await fetch("/api/customer/" + id + "/bills");
        const bills = await res.json();

        const table = document.getElementById("billTable");

        table.innerHTML = "";

        bills.forEach((b) => {
          const tr = document.createElement("tr");

          tr.innerHTML = `
            <td>${b.id}</td>
            <td>${b.package_name}</td>
            <td>${b.original_price}</td>
            <td>${b.discount}%</td>
            <td>${b.final_price}</td>
            <td>${b.created_at.split("T")[0]}</td>
          `;

          table.appendChild(tr);
        });
      }

      load();
      loadBills();

      document.getElementById("form").onsubmit = async (e) => {
        e.preventDefault();
        const nameInput = document.getElementById("name");
        const phoneInput = document.getElementById("phone");
        const endInput = document.getElementById("end");
        const statusInput = document.getElementById("status");
        const noteInput = document.getElementById("note");

        await fetch("/api/customer/" + id, {
          method: "PUT",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            name: nameInput.value,
            phone: phoneInput.value,
            end_date: endInput.value,
            status: statusInput.value,
            note: noteInput.value,
          }),
        });

        location.href = "/admin/customer/edit?id=" + id;
      };

      async function deleteCustomer() {
        await fetch("/api/customer/" + id, {
          method: "DELETE",
        });

        location.href = "/admin/customer";
      }
    </script>
  </body>
</html>
